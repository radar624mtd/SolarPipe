{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /c/Users/radar/SolarPipe && dotnet build --no-restore 2>&1 | tail -20"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo $CLAUDE_TOOL_INPUT | grep -q 'Directory.Packages.props' && echo 'REMINDER: After editing Directory.Packages.props, run dotnet restore' || true"
          }
        ]
      }
    ]
  }
}
